# Optional: where the MockDesk UI thinks the companion lives (copy buttons, default API base URLs).
VITE_COMPANION_HTTP_ORIGIN=http://127.0.0.1:8787
VITE_COMPANION_WS_ORIGIN=ws://127.0.0.1:8787

# Live gateway: UI pushes mocks here (default in dev). Set to 0 to disable. Production: set full URL at build time.
# VITE_LIVE_MOCK_SYNC=0
# VITE_LIVE_MOCK_SYNC_URL=http://127.0.0.1:8787/__mockdesk/sync
# VITE_LIVE_MOCK_SYNC_SECRET=your-secret
